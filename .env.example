PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/x666

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-to-another-long-random-string

# Frontend URL for referral share links (not the API URL)
APP_BASE_URL=http://localhost:3000

# Email OTP (Nodemailer)
SMTP_USE_ETHEREAL=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=x666 <you@gmail.com>

# SMS OTP (Twilio) — forgot-password, wallet withdraw
# Dev: leave blank to log OTP codes in the terminal instead of sending SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Manual bank transfer payments
PAYMENT_CURRENCY=PKR
TOPUP_REQUEST_TTL_HOURS=24
OCR_TIMESTAMP_WINDOW_MINUTES=30
WITHDRAW_HOLD_HOURS=48
MAX_TOPUP_PER_TRANSACTION=50000
MAX_TOPUP_PER_DAY=100000
MAX_TOPUP_PER_DAY_NEW_USER=10000
NEW_USER_DAYS=7
MAX_PENDING_TOPUPS_PER_USER=5
PHASH_SIMILARITY_THRESHOLD=10
UPLOAD_DIR=uploads/receipts
RECEIPT_DIR=uploads/payment-receipts
MAX_RECEIPT_UPLOAD_BYTES=5242880

# First admin bootstrap (optional — created on startup if no admin exists)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me-admin-password
ADMIN_SEED_NAME=Platform Admin

OTP_DEV_FIXED_CODE=999999

# Legacy x-admin-key routes removed — admin panel uses JWT role=admin
# PLATFORM_DEPOSIT_ACCOUNTS=[{"bankName":"HBL","accountTitle":"x666 Official","iban":"PK00HBL0000000000000000","gateway":"bank","label":"HBL Bank Transfer","instructions":"Include TOPUP reference in transfer note."}]
