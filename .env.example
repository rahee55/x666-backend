PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/x666

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-to-another-long-random-string

# Frontend URL for referral share links (not the API URL)
APP_BASE_URL=http://localhost:3000

# Email OTP (Nodemailer)
SMTP_USE_ETHEREAL=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=x666 <you@gmail.com>

# SMS OTP (Twilio) — forgot-password, wallet top-up/withdraw
# Dev: leave blank to log OTP codes in the terminal instead of sending SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Safepay Payments 2.0
SAFEPAY_MERCHANT_API_KEY=
SAFEPAY_SECRET_KEY=
SAFEPAY_ENV=sandbox
SAFEPAY_HOST=https://sandbox.api.getsafepay.com
SAFEPAY_CURRENCY=PKR
SAFEPAY_REDIRECT_URL=http://localhost:3001/api/wallet/topup/callback
SAFEPAY_CANCEL_URL=http://localhost:3001/api/wallet/topup/cancel
SAFEPAY_FRONTEND_SUCCESS_PATH=/wallet/topup/success
SAFEPAY_FRONTEND_CANCEL_PATH=/wallet/topup/cancel
SAFEPAY_WITHDRAW_MODE=sandbox_auto
# SAFEPAY_AGGREGATOR_ID=
# SAFEPAY_AGGREGATOR_SECRET_KEY=
# SAFEPAY_RAAST_HOST=https://dev.api.getsafepay.com/raastwire
